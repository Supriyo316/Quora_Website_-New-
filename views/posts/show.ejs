<% layout('layouts/boilerplate') %>
<% title = post.author.username + "'s Post" %>

<div class="page-container">
    <a href="/posts" class="back-link">← Back to Feed</a>

    <div class="show-card">
        <div class="post-meta">
            <div class="avatar"><%= post.author.username.charAt(0).toUpperCase() %></div>
            <div>
                <div class="post-username"><%= post.author.username %></div>
            </div>
        </div>

        <p class="post-content"><%= post.content %></p>

        <div class="show-meta-row">
            <span class="meta-chip">📅 <%= post.createdAt.toLocaleString() %></span>
            <% if (post.updatedAt.getTime() !== post.createdAt.getTime()) { %>
                <span class="meta-chip">✏️ Updated: <%= post.updatedAt.toLocaleString() %></span>
            <% } %>
        </div>

        <% if (currentUser && post.author._id.equals(currentUser._id)) { %>
            <div class="show-actions">
                <a href="/posts/<%= post._id %>/edit" class="btn btn-primary">
                    <span>✏️</span> Edit Post
                </a>
                <form method="post" action="/posts/<%= post._id %>?_method=DELETE" class="inline-form">
                    <button class="btn btn-danger" type="submit" onclick="return confirm('Delete this post?')">
                        <span>🗑</span> Delete
                    </button>
                </form>
            </div>
        <% } %>
    </div>
</div>